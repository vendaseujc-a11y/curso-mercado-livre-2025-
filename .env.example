# Configuração do MongoDB Atlas
# Siga os passos em https://www.mongodb.com/cloud/atlas

# Connection string do MongoDB Atlas (substitua com suas credenciais)
# O formato é: mongodb+srv://usuario:senha@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority
MONGO_URI=mongodb+srv://<SEU_USUARIO>:<SUA_SENHA>@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority

# Porta do servidor
PORT=3000